{
  "buildCommand": "npm run build:shared && npm run build:frontend",
  "outputDirectory": "packages/frontend/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-url.com/api/:path*"
    }
  ]
}
