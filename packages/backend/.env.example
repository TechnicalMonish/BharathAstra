# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Table Prefix
DYNAMODB_TABLE_PREFIX=bharathastra

# S3 Bucket for document caching
S3_BUCKET_NAME=bharathastra-docs-cache

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,https://bharath-astra.vercel.app

# Bedrock Model Configuration (optional - defaults shown)
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v1
BEDROCK_LLM_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
